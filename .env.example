# Dagens Environment Configuration
# Copy this file to .env and fill in your values

# OpenRouter API Key (required for AI agent execution)
# Get your key from https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: etcd endpoints for cluster-aware mode
# Leave empty for static/single-node mode
ETCD_ENDPOINTS=

# Optional: Vault configuration for secrets management
VAULT_ADDR=
VAULT_TOKEN=

# Optional: OTEL configuration (docker-compose sets these automatically)
# OTEL_EXPORTER_TYPE=otlp
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=dagens

# Optional: Enable development mode (disables authentication)
# DEV_MODE=true
